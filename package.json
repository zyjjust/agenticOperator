{
  "name": "agentic-operator",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "npm run inngest:up && next dev -p 3002",
    "dev:next-only": "next dev -p 3002",
    "inngest:up": "docker compose -f docker-compose.inngest.yml up -d",
    "inngest:down": "docker compose -f docker-compose.inngest.yml down",
    "inngest:logs": "docker compose -f docker-compose.inngest.yml logs -f",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "prisma db push",
    "db:reset": "rm -f data/ao.db data/ao.db-journal data/ao.db-wal data/ao.db-shm && prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed-from-sidecars.ts",
    "register": "npx tsx scripts/register-with-inngest.ts"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "eventsource-parser": "^3.0.8",
    "inngest": "^4.3.0",
    "minio": "^8.0.7",
    "neo4j-driver": "^6.0.1",
    "next": "16.2.4",
    "openai": "^6.34.0",
    "pdf-parse": "^2.4.5",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "unpdf": "^1.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^22.9.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.4.20",
    "better-sqlite3": "^12.9.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "happy-dom": "^20.9.0",
    "postcss": "^8.4.49",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  }
}
