{
  "name": "agentic-operator",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -n next,ws,em,inngest -c blue,cyan,green,magenta -k --kill-others-on-fail \"next dev -p 3002\" \"npm --prefix Action_and_Event_Manager/workflow-studio/server run dev\" \"npm --prefix Action_and_Event_Manager/packages/server run dev\" \"npx -y inngest-cli@latest dev\"",
    "dev:next-only": "next dev -p 3002",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "happy-dom": "^20.9.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  }
}
