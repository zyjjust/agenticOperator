// AO unified Prisma schema (P3 foundation)
//
// Design principles (from spec):
// - Single SQLite file `data/ao.db` for dev (env-overridable for prod Postgres).
// - Only runtime/audit/gateway models from EM (Q1: no Editor).
// - WS workflow models, minus Copilot (Q2) and test/studio/simulation tables.
// - All Postgres-specific (@db.Text, @db.VarChar(N), arrays) stripped for SQLite.
// - JSON columns stored as TEXT, parsed by service layer.
//
// P3 progress: foundation (~10 of ~25 final tables). Remaining tables and
// migration plan documented in docs/superpowers/specs/2026-04-27-ao-int-p3-monorepo-merge-design.md §4.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// =====================================================================
// WS — Workflow runtime
// =====================================================================

model WorkflowRun {
  id               String    @id @default(cuid())
  triggerEvent     String
  triggerData      String    // JSON
  // status values per spec §13: running | suspended | timed_out | completed
  // | failed | paused | interrupted
  status           String    @default("running")
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  lastActivityAt   DateTime  @default(now())
  suspendedReason  String?

  steps            WorkflowStep[]
  activities       AgentActivity[]

  @@index([status])
  @@index([startedAt])
  @@index([lastActivityAt])
}

model WorkflowStep {
  id          String    @id @default(cuid())
  runId       String
  run         WorkflowRun @relation(fields: [runId], references: [id])
  nodeId      String
  stepName    String
  status      String    // pending | running | completed | failed | retrying
  input       String?   // JSON
  output      String?   // JSON
  error       String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  durationMs  Int?

  @@index([runId])
  @@index([nodeId])
  @@index([status])
}

model AgentActivity {
  id        String   @id @default(cuid())
  runId     String?
  run       WorkflowRun? @relation(fields: [runId], references: [id])
  nodeId    String
  agentName String
  type      String
  narrative String
  metadata  String?  // JSON
  createdAt DateTime @default(now())

  @@index([runId])
  @@index([nodeId])
  @@index([agentName])
  @@index([type])
  @@index([createdAt])
}

model HumanTask {
  id            String    @id @default(cuid())
  runId         String
  nodeId        String
  nodeName      String
  title         String
  payload       String    // JSON
  aiOpinion     String?   // JSON
  status        String    @default("pending") // pending | approved | rejected
  assignee      String?
  result        String?   // JSON
  createdAt     DateTime  @default(now())
  completedAt   DateTime?
  deadline      DateTime?
  approveEvent  String?
  rejectEvent   String?
  eventData     String?   // JSON
  resolvedBy    String?

  // EM v2 spec §10.4 — when an agent escalates via business rules, it must
  // record the EventInstance that triggered the escalation. Lets /inbox
  // cards link back to /events/:name/instances/:id. Optional today (legacy
  // tasks lack it) but populated by all new agent code paths.
  triggeringEventInstanceId String?  @map("triggering_event_instance_id")
  triggeringEventName       String?  @map("triggering_event_name")

  @@index([runId])
  @@index([status])
  @@index([nodeId])
  @@index([assignee])
  @@index([triggeringEventInstanceId])
}

model ChatbotSession {
  id                 String    @id @default(cuid())
  sessionType        String
  status             String    @default("open")
  correlationId      String
  humanTaskId        String?
  hitlRequestId      String?
  parentSessionId    String?
  clientId           String?
  assignedTo         String?
  aiAnalysis         String?   // JSON
  questions          String    // JSON
  collectedAnswers   String    @default("{}")
  conversationLog    String    @default("[]")
  resolvedPath       String?
  resolvedBy         String?
  resolvedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deadline           DateTime?

  @@index([correlationId])
  @@index([status])
  @@index([humanTaskId])
}

// Living KB rules (used by processResume.rule etc.)
model CandidateLock {
  id           String   @id @default(cuid())
  candidateId  String
  clientId     String
  jdId         String?
  recruiterId  String
  expiresAt    DateTime
  reason       String?
  releasedAt   DateTime?
  createdAt    DateTime @default(now())

  @@index([candidateId, clientId])
  @@index([clientId, expiresAt])
}

model Blacklist {
  id           String   @id @default(cuid())
  candidateId  String
  clientId     String?
  reason       String
  addedBy      String
  createdAt    DateTime @default(now())

  @@index([candidateId, clientId])
}

// =====================================================================
// EM — Audit & DLQ (runtime only, no Editor)
// =====================================================================

model AuditLog {
  id           String   @id @default(cuid())
  eventName    String
  traceId      String
  payload      String   // JSON
  payloadDigest String
  source       String   // 'ws' | 'em' | 'external'
  createdAt    DateTime @default(now())

  @@index([eventName])
  @@index([traceId])
  @@index([createdAt])
}

model DLQEntry {
  id        String   @id @default(cuid())
  eventName String
  reason    String
  payload   String   // JSON
  retries   Int      @default(0)
  createdAt DateTime @default(now())
  resolvedAt DateTime?

  @@index([eventName])
  @@index([resolvedAt])
}

model DedupCache {
  id          String   @id @default(cuid())
  dedupKey    String   @unique
  eventName   String
  firstSeenAt DateTime @default(now())
  hitCount    Int      @default(1)

  @@index([eventName])
  @@index([firstSeenAt])
}

// =====================================================================
// WS — Living KB Layer 4 (Episodes) + AgentConfig
// =====================================================================

// One row per agent execution. Powers /api/trace LLM-trace tab and the
// agent-tuning loop (judgeScore + reviewerFeedback).
model AgentEpisode {
  id               String   @id @default(cuid())
  agentName        String
  runId            String?
  workflowId       String?
  clientId         String?
  input            String   // JSON
  output           String   // JSON
  toolTrace        String?  // JSON
  ruleEvaluations  String?  // JSON
  durationMs       Int
  modelUsed        String?
  tokenUsage       String?  // JSON: {prompt, completion, total}
  judgeScore       Float?
  judgeRationale   String?
  judgedAt         DateTime?
  reviewerFeedback String?
  reviewedBy       String?
  reviewedAt       DateTime?
  isFewShot        Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@index([agentName])
  @@index([runId])
  @@index([clientId, agentName])
  @@index([judgeScore])
  @@index([isFewShot])
  @@index([createdAt])
}

// Per-agent runtime overrides (temperature, prompt append, tier, retries).
// Edited via /api/agent-config (P3 chunk 4) and ConfigAdvisor agent.
model AgentConfig {
  id               String  @id  // matches WorkflowAgentDef.id
  enabled          Boolean @default(true)
  description      String?
  temperature      Float?
  maxRetries       Int?
  tier             String?  // "lite" | "standard" | "pro"
  maxOutputTokens  Int?
  promptAppend     String?
  skillOverrides   String?  // JSON: Record<string, Partial<AIConfig>>
  tuningNotes      String?
  lastAdvisedAt    DateTime?
  adviceAccepted   Boolean  @default(false)
  updatedAt        DateTime @updatedAt
  history          AgentConfigHistory[]
}

model AgentConfigHistory {
  id        String   @id @default(cuid())
  agentId   String
  config    AgentConfig @relation(fields: [agentId], references: [id])
  changedBy String   @default("user")
  before    String   // JSON
  after     String   // JSON
  reason    String?
  createdAt DateTime @default(now())

  @@index([agentId])
  @@index([createdAt])
}

// =====================================================================
// EM — Runtime / Gateway / Outbound (Q1: no Editor)
// =====================================================================

// EM event-definition table; AO reads ACTIVE rows only as event-contract
// cache. No edit operations exposed by AO.
//
// v2 spec additions (additive, optional):
//   activeVersionsJson: JSON array of version strings, descending (latest first)
//   schemasByVersionJson: JSON object { "2.0": <jsonschema>, "1.0": ... }
//   publishersJson / subscribersJson: JSON string[]
//   source: 'neo4j' (synced) | 'hardcoded' (fallback) | 'manual'
//   syncedAt: last successful Neo4j sync
//   retiredAt: hide from UI when set
model EventDefinition {
  id          String  @id @default(uuid())
  name        String  @unique
  description String
  payload     String  // JSON
  extraJson   String  @default("{}") @map("extra_json")
  status      String  @default("DRAFT")
  version     String  @default("1.0")
  sortOrder   Int     @default(0) @map("sort_order")
  batchId     String? @map("batch_id")
  createdAt   String  @map("created_at")
  updatedAt   String  @map("updated_at")

  // v2 additive fields
  activeVersionsJson    String?   @map("active_versions_json")    // JSON: string[]
  schemasByVersionJson  String?   @map("schemas_by_version_json") // JSON: Record<version, JsonSchema>
  publishersJson        String?   @map("publishers_json")         // JSON: string[]
  subscribersJson       String?   @map("subscribers_json")        // JSON: string[]
  source                String    @default("hardcoded")            // 'neo4j' | 'hardcoded' | 'manual'
  syncedAt              DateTime? @map("synced_at")
  retiredAt             DateTime? @map("retired_at")

  // Change detection: SHA-256(description + payload + extraJson + publishers
  // + subscribers). Sync compares this against the new computed hash to
  // decide whether the row actually changed (vs. just got re-touched). If
  // it changed, lastChangedAt is set to NOW().
  contentHash           String?   @map("content_hash")
  lastChangedAt         DateTime? @map("last_changed_at")

  // Allmeta sets `is_breaking_change` on the Event node when a published
  // version contains a non-back-compatible mutation. We surface this so
  // /events shows a red badge and ops knows to verify nothing in flight
  // depends on the old shape.
  isBreakingChange      Boolean   @default(false) @map("is_breaking_change")

  @@index([source, syncedAt])
  @@index([retiredAt])
  @@index([lastChangedAt])
  @@map("events")
}

// EM v2 §9 — EventInstance: business-level publish trail. One row per
// em.publish() call. Inngest stores the full payload; this table stores
// summary + provenance + lifecycle status for UI / audit / replay.
model EventInstance {
  id                  String    @id @default(uuid())
  externalEventId     String?   @unique @map("external_event_id")
  name                String
  source              String                              // "raas-bridge" | "rpa.matchResumeAgent" | ...
  status              String                              // accepted | rejected_schema | rejected_filter | duplicate | meta_rejection | em_degraded
  rejectionType       String?   @map("rejection_type")    // SCHEMA_VALIDATION_FAILED | FILTER_REJECTED
  rejectionReason     String?   @map("rejection_reason")
  schemaErrors        String?   @map("schema_errors")     // JSON: ZodIssue[]
  schemaVersionUsed   String?   @map("schema_version_used")
  triedVersions       String?   @map("tried_versions")    // JSON: string[]
  causedByEventId     String?   @map("caused_by_event_id")
  causedByName        String?   @map("caused_by_name")
  payloadSummary      String?   @map("payload_summary")   // JSON snippet
  ts                  DateTime  @default(now())

  @@index([name, ts])
  @@index([status])
  @@index([causedByEventId])
  @@index([source])
  @@map("event_instances")
}

// EM library health snapshot (singleton row id='singleton').
// Driven by server/em/degraded-mode.ts. UI reads to render AppBar dot etc.
model EmSystemStatus {
  id                String    @id @default("singleton")
  state             String    @default("healthy")  // 'healthy' | 'degraded' | 'down'
  degradedSince     DateTime? @map("degraded_since")
  lastError         String?   @map("last_error")
  lastErrorAt       DateTime? @map("last_error_at")
  fallbackCount24h  Int       @default(0) @map("fallback_count_24h")
  publishCount24h   Int       @default(0) @map("publish_count_24h")
  rejectCount24h    Int       @default(0) @map("reject_count_24h")
  // Neo4j sync sub-status
  neo4jLastSyncAt   DateTime? @map("neo4j_last_sync_at")
  neo4jLastError    String?   @map("neo4j_last_error")
  neo4jUpsertedLast Int       @default(0) @map("neo4j_upserted_last")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@map("em_system_status")
}

model GatewayFilterRule {
  id               String  @id @default(uuid())
  ruleType         String  @map("rule_type") // whitelist | blacklist | auto_map
  eventNamePattern String  @map("event_name_pattern")
  targetEventId    String? @map("target_event_id")
  enabled          Int     @default(1)
  description      String?
  createdAt        String  @map("created_at")

  @@map("gateway_filter_rules")
}

// Phase 7 outbound — terminal agents enqueue here for external delivery.
model OutboundEvent {
  id              String  @id @default(uuid())
  correlationId   String  @map("correlation_id")
  eventName       String  @map("event_name")
  eventId         String  @map("event_id")
  payload         String  // JSON
  expectAckEvent  String? @map("expect_ack_event")
  status          String  @default("sent") // sent | pending | acknowledged | timeout | failed | chained
  sentAt          String  @map("sent_at")
  ackReceivedAt   String? @map("ack_received_at")
  ackMessageId    Int?    @map("ack_message_id")
  timeoutSeconds  Int     @default(300) @map("timeout_seconds")
  extraMetadata   String? @map("extra_metadata") // JSON

  @@index([correlationId])
  @@index([status])
  @@map("outbound_events")
}

// Inbound RaaS messages from external Kafka — full audit trail.
model RaasMessage {
  id                Int     @id @default(autoincrement())
  receivedAt        String  @map("received_at")
  topic             String
  partition         Int     @default(0)
  offset            Int
  key               String?
  data              String  // JSON
  classification    String? // matched_valid | matched_invalid | unrecognized | parse_error
  matchedEventDefId String? @map("matched_event_def_id")
  validationErrors  String? @map("validation_errors") // JSON array
  classifiedAt      String? @map("classified_at")
  ingestionStatus   String? @map("ingestion_status") // pending | ingested | failed | skipped
  ingestedAt        String? @map("ingested_at")

  @@index([classification], map: "idx_raas_classification")
  @@index([ingestionStatus], map: "idx_raas_ingestion_status")
  @@map("raas_messages")
}

model RejectedMessage {
  id           String  @id
  rawPayload   String? @map("raw_payload")
  rejectReason String  @map("reject_reason") // malformed_json | missing_event_name | unknown_source | out_of_domain
  source       String?
  receivedAt   String  @map("received_at")

  @@map("rejected_messages")
}

model IngestionConfig {
  id         String @id @default(uuid())
  eventName  String @unique @map("event_name")
  autoIngest Int    @default(0) @map("auto_ingest")
  createdAt  String @map("created_at")
  updatedAt  String @map("updated_at")

  @@map("ingestion_configs")
}

model HealthIncident {
  id            String  @id
  healthState   String  @map("health_state") // YELLOW | RED
  failedEvent   String? @map("failed_event")
  failureReason String? @map("failure_reason")
  agentName     String? @map("agent_name")
  sampledAt     String  @map("sampled_at")
  resolved      Int     @default(0)

  @@map("health_incidents")
}

model ExecutionTrace {
  id           String  @id @default(uuid())
  triggerEvent String  @map("trigger_event")
  mode         String  @default("simulated") // simulated | live
  steps        String  @default("[]") // JSON array
  summary      String  @default("{}") // JSON
  startedAt    String  @map("started_at")
  completedAt  String? @map("completed_at")
  maxDepth     Int     @default(10) @map("max_depth")

  @@map("execution_traces")
}

// =====================================================================
// Recruitment workflow: requirement → JD pipeline (workflow nodes 1-2 → 4)
// =====================================================================

model JobRequisition {
  id              String   @id                 // requisition_id (uuid or short)
  client          String                       // 客户名 / company name
  title           String                       // 岗位名称
  city            String?
  headcount       Int?                         // 计划招聘人数
  salaryRangeMin  Int?                         // CNY/月
  salaryRangeMax  Int?
  responsibilities String?                     // 岗位职责（多行 markdown）
  requirements     String?                     // 任职要求（硬性 + 软性）
  niceToHaves      String?                     // 加分项
  source           String   @default("manual") // manual | sync
  status           String   @default("pending_clarification")
                                                // pending_clarification | clarified | jd_ready | published | closed
  rawPayload       String?                     // 原始 REQUIREMENT_LOGGED payload (JSON string)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  jds              JobDescription[]
}

model JobDescription {
  id                   String   @id              // jd_id (uuid)
  requisitionId        String                    // FK → JobRequisition.id
  client               String
  title                String                    // 标准化职位名称
  jdContent            String                    // 完整 JD 文本（markdown / JSON-string）
  responsibilities     String?
  requirements         String?
  niceToHaves          String?
  searchKeywords       String?                   // top-5 keywords as comma-separated string
  qualityScore         Float?
  qualitySuggestions   String?                   // JSON string array
  marketCompetitiveness String?                  // 高 / 中 / 低

  // ── 结构化匹配签名（per JOB_REQUISITION_GENERATED.payload） ──
  mustHaveSkills       String?                   // JSON string of string[]
  niceToHaveSkills     String?                   // JSON string of string[]
  degreeRequirement    String?                   // 本科及以上 / 硕士及以上 / 不限
  educationRequirement String?                   // 计算机相关专业 / 不限
  languageRequirements String?                   // 英语读写流利 / 无
  negativeRequirement  String?                   // 排除条件
  workYears            Int?                      // 最少工作年限
  expectedLevel        String?                   // T3-T4 / 中3-高1
  interviewMode        String?                   // 现场面试 / 视频面试

  status               String   @default("draft") // draft | approved | rejected | published
  generatorMode        String?                   // robohire | llm | manual
  generatorModel       String?                   // model used (e.g. gemini-3-flash-preview)
  generatorRequestId   String?
  generatorDurationMs  Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  requisition          JobRequisition @relation(fields: [requisitionId], references: [id])
}

// =====================================================================
// Schema status: 24 tables (10 P3-foundation + 12 chunk-1 + 2 recruitment).
//
// Skipped for later (advanced ML/KB; not consumed by current AO routes —
