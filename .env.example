# ─────────────────────────────────────────────────────────────────────
#  Agentic Operator — environment template
#  Copy this file to `.env.local` and fill in values you actually use.
#  Do NOT commit `.env` or `.env.local` — they're in .gitignore.
#
#  NOTE: the current frontend is mock-only and reads no env vars.
#  These keys are scaffolding for when a backend / LLM gateway / data
#  layer is added. Set only what you need.
# ─────────────────────────────────────────────────────────────────────


# ═════════════════════════════════════════════════════════════════════
#  1. Persistence
#     P3 default: SQLite single file at data/ao.db (no external DB).
#     For prod: override to postgres://... and switch prisma datasource
#     provider to "postgresql" in prisma/schema.prisma.
# ═════════════════════════════════════════════════════════════════════
DATABASE_URL="file:./data/ao.db"

# P1/P2: AO talks to live EM/WS sidecars over HTTP. P3 fully merges these
# into AO Next.js — these vars become unused.
WS_BASE_URL=http://localhost:5175
EM_BASE_URL=http://localhost:8000

# Inngest (dev: inngest-cli; prod: cloud or self-hosted)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Old style — kept for backward compatibility with cloud Postgres deployment
# DATABASE_URL=postgres://user:password@localhost:5432/agentic_operator

# Optional — Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Pool tuning (optional)
DATABASE_POOL_MAX=20
DATABASE_IDLE_TIMEOUT=30000
DATABASE_CONNECT_TIMEOUT=5000


# ═════════════════════════════════════════════════════════════════════
#  2. LLM provider API keys
#  Set keys only for providers you actually use.
# ═════════════════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional — point at Azure OpenAI / self-hosted proxy:
# OPENAI_BASE_URL=https://api.openai.com/v1

GOOGLE_API_KEY=

OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_APP_TITLE=Agentic Operator

MOONSHOT_API_KEY=
MINIMAX_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
XAI_API_KEY=

# Local LLM (ollama / vLLM / LM Studio / llama.cpp). OpenAI-compatible.
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_API_KEY=local


# ═════════════════════════════════════════════════════════════════════
#  3. Default routing — fallback when no DB rule matches
# ═════════════════════════════════════════════════════════════════════
LLM_DEFAULT_PROVIDER=openrouter
LLM_DEFAULT_MODEL=
LLM_FAST_MODEL=
LLM_CHEAP_MODEL=
LLM_REASONING_MODEL=
LLM_HIGH_REASONING_MODEL=
LLM_EXTRACT_MODEL=
LLM_SUMMARIZE_MODEL=


# ═════════════════════════════════════════════════════════════════════
#  4. Knowledge graph & object storage
# ═════════════════════════════════════════════════════════════════════
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_REGION=us-east-1


# ═════════════════════════════════════════════════════════════════════
#  5. Agent runtime knobs (optional)
# ═════════════════════════════════════════════════════════════════════
AGENT_MAX_STEPS=12
AGENT_STEP_TIMEOUT_MS=120000
LOG_LEVEL=info


# ═════════════════════════════════════════════════════════════════════
#  6. App config — exposed to the browser (NEXT_PUBLIC_*)
# ═════════════════════════════════════════════════════════════════════
# Default UI locale on first load. Overridden by user toggle (zh / en).
NEXT_PUBLIC_DEFAULT_LOCALE=zh
