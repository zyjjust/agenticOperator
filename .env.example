# ─────────────────────────────────────────────────────────────────────
#  Agentic Operator — environment template
#  Copy this file to `.env.local` and fill in values you actually use.
#  Do NOT commit `.env` or `.env.local` — they're in .gitignore.
#
#  NOTE: the current frontend is mock-only and reads no env vars.
#  These keys are scaffolding for when a backend / LLM gateway / data
#  layer is added. Set only what you need.
# ─────────────────────────────────────────────────────────────────────


# ═════════════════════════════════════════════════════════════════════
#  1. Persistence
#     P3 default: SQLite single file at data/ao.db (no external DB).
#     For prod: override to postgres://... and switch prisma datasource
#     provider to "postgresql" in prisma/schema.prisma.
# ═════════════════════════════════════════════════════════════════════
DATABASE_URL="file:./data/ao.db"

# P1/P2: AO talks to live EM/WS sidecars over HTTP. P3 fully merges these
# into AO Next.js — these vars become unused.
WS_BASE_URL=http://localhost:5175
EM_BASE_URL=http://localhost:8000

# RAAS API (proxies RoboHire — AO must NOT call api.robohire.io directly).
# Dev: http://localhost:3001  |  Prod: https://aicoe.chinasoftinc.com/raas-api
# AGENT_API_KEY is issued by the raas team (dev / staging / prod sets differ).
RAAS_API_BASE_URL=http://localhost:3001
AGENT_API_KEY=

# Inngest (dev: inngest-cli; prod: cloud or self-hosted)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Old style — kept for backward compatibility with cloud Postgres deployment
# DATABASE_URL=postgres://user:password@localhost:5432/agentic_operator

# Optional — Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Pool tuning (optional)
DATABASE_POOL_MAX=20
DATABASE_IDLE_TIMEOUT=30000
DATABASE_CONNECT_TIMEOUT=5000


# ═════════════════════════════════════════════════════════════════════
#  2. LLM provider API keys
#  Set keys only for providers you actually use.
# ═════════════════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional — point at Azure OpenAI / self-hosted proxy:
# OPENAI_BASE_URL=https://api.openai.com/v1

GOOGLE_API_KEY=

OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_APP_TITLE=Agentic Operator

MOONSHOT_API_KEY=
MINIMAX_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
XAI_API_KEY=

# Local LLM (ollama / vLLM / LM Studio / llama.cpp). OpenAI-compatible.
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_API_KEY=local


# ═════════════════════════════════════════════════════════════════════
#  3. Default routing — fallback when no DB rule matches
# ═════════════════════════════════════════════════════════════════════
LLM_DEFAULT_PROVIDER=openrouter
LLM_DEFAULT_MODEL=
LLM_FAST_MODEL=
LLM_CHEAP_MODEL=
LLM_REASONING_MODEL=
LLM_HIGH_REASONING_MODEL=
LLM_EXTRACT_MODEL=
LLM_SUMMARIZE_MODEL=


# ═════════════════════════════════════════════════════════════════════
#  4. Knowledge graph & object storage
# ═════════════════════════════════════════════════════════════════════
# RAAS shared Neo4j (internal VPN only — won't reach without VPN).
# Source of truth for EventDefinition; AO syncs read-only every 5 min.
RAAS_LINKS_NEO4J_URI=neo4j://10.100.0.70:7687
RAAS_LINKS_NEO4J_USER=neo4j
RAAS_LINKS_NEO4J_PASSWORD=
RAAS_LINKS_NEO4J_DATABASE=neo4j
# Set to "0" to skip the boot-time sync (useful when off-VPN).
NEO4J_SYNC_ENABLED=1
# Sync poll interval (default 5 min)
NEO4J_SYNC_INTERVAL_MS=300000

# Legacy (kept for compat — fall back to these if RAAS_LINKS_* unset).
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_REGION=us-east-1


# ═════════════════════════════════════════════════════════════════════
#  5. Agent runtime knobs (optional)
# ═════════════════════════════════════════════════════════════════════
AGENT_MAX_STEPS=12
AGENT_STEP_TIMEOUT_MS=120000
LOG_LEVEL=info

# EM schema enforcement.
# Default (unset / false): events with no registered schema pass through as
# "unvalidated" — event stream stays populated during integration testing.
# Set to "true" in production to enforce strict schema validation and reject
# unregistered events with EVENT_REJECTED.
# Events that DO have a registered schema always get validated regardless.
EM_STRICT_SCHEMA=false


# ═════════════════════════════════════════════════════════════════════
#  6. App config — exposed to the browser (NEXT_PUBLIC_*)
# ═════════════════════════════════════════════════════════════════════
# Default UI locale on first load. Overridden by user toggle (zh / en).
NEXT_PUBLIC_DEFAULT_LOCALE=zh


# ═════════════════════════════════════════════════════════════════════
#  7. Ontology codegen (npm run gen:v4-snapshot)
#  Also read by /dev/generate-prompt's "Live" mode (server action).
# ═════════════════════════════════════════════════════════════════════
ONTOLOGY_API_BASE=http://localhost:3500
ONTOLOGY_API_TOKEN=
